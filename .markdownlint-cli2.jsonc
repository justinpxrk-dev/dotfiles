{
  "globs": ["**/*.md"],
  // Vendored/submodule trees, plus .venv (ships a stray README.md). Mostly
  // mirrors .prettierignore, except .claude: markdownlint skips it (its
  // SKILL.md are symlinks already linted once under .agents/skills/), while
  // prettier still formats it. See AGENTS.md "Keeping Config in Sync".
  "ignores": [
    "node_modules",
    ".venv",
    ".claude",
    "Library/Fonts",
    "Library/Wallpapers",
    "Library/Themes/tinted",
    "Library/Themes/Catppuccin",
    "dot_config/sketchybar/lib",
    "Library/Unmanaged",
    ".obsidian"
  ],
  "config": {
    // Prettier owns line wrapping for Markdown.
    "MD013": false,
    // README's layout tables are tab-indented HTML by design.
    "MD010": false,
    "MD033": false,
    // Some docs open with YAML frontmatter or prose rather than an h1.
    "MD041": false,
    // Allow repeated sub-headings (e.g. "Dark Mode"/"Light Mode") as long
    // as they sit under different parent headings.
    "MD024": { "siblings_only": true }
  }
}
