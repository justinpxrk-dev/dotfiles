{
  "globs": ["**/*.md"],
  // Vendored/submodule trees — kept in sync with .prettierignore (plus
  // .venv, which ships a stray README.md). See AGENTS.md "Keeping Config
  // in Sync".
  "ignores": [
    "node_modules",
    ".venv",
    ".claude",
    ".codex",
    "Library/Fonts",
    "Wallpapers",
    "Themes/lib",
    "dot_config/sketchybar/lib",
    "Unmanaged",
    ".obsidian"
  ],
  "config": {
    // Prettier owns line wrapping for Markdown.
    "MD013": false,
    // README's layout tables are tab-indented HTML by design.
    "MD010": false,
    "MD033": false,
    // Skill docs (SKILL.md) intentionally open with prose, not an h1.
    "MD041": false,
    // Allow repeated sub-headings (e.g. "Dark Mode"/"Light Mode") as long
    // as they sit under different parent headings.
    "MD024": { "siblings_only": true }
  }
}
