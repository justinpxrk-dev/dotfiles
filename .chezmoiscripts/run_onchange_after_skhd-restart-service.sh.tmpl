#!/usr/bin/env bash
# Restart skhd only when its Homebrew version (embedded below) changes.
# `after_` runs this past the brew-bundle step; `|| true` keeps rendering safe
# when brew/skhd is absent.
#
# {{ output "bash" "-c" "brew list --versions skhd 2>/dev/null || true" | trim }}
set -euo pipefail

# Skip cleanly if skhd is absent (uninstalled out of band) instead of aborting;
# re-triggers once its version returns.
command -v skhd >/dev/null || { echo "skhd not installed; skipping restart" >&2; exit 0; }

# Restart if loaded (upgrade), else start fresh (first install).
skhd --restart-service 2>/dev/null || skhd --start-service
