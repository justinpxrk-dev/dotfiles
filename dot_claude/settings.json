{
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); branch=$(git -C \"$(echo \"$input\" | jq -r '.workspace.current_dir')\" --no-optional-locks branch --show-current 2>/dev/null); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); dir=$(basename \"$cwd\"); out=\"$dir\"; [ -n \"$branch\" ] && out=\"$out  $branch\"; printf '%s' \"$out\""
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "woz@wozcode-marketplace": true
  },
  "extraKnownMarketplaces": {
    "wozcode-marketplace": {
      "source": {
        "source": "github",
        "repo": "WithWoz/wozcode-plugin"
      }
    }
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "xhigh",
  "agent": "woz:code-free",
  "tui": "default",
  "autoMemoryEnabled": false,
  "theme": "auto",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "wozcode": {
    "spinnerVerbs": false,
    "statusLineLifetime": false,
    "statusLineShare": false,
    "attribution": false
  }
}
