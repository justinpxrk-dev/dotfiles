[user]
    email = 192945419+justinpxrk-dev@users.noreply.github.com
    name = Justin Park

[url "ssh://git@github.com"]
    insteadOf = https://github.com

[core]
    ignoreCase = false
    pager = delta

[branch]
    sort = -committerdate

[column]
    ui = auto

[delta]
    navigate = true

[diff]
    algorithm = histogram

[help]
    autocorrect = prompt

[interactive]
    diffFilter = delta --color-only

[merge]
    conflictStyle = zdiff3

[rerere]
    enabled = true
[fetch]
    prune = true

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[rebase]
    autoStash = true
    autoSquash = true