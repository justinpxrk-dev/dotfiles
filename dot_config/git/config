[core]
    editor = nvim
    pager = delta

[branch]
    sort = -committerdate

[column]
    ui = auto

[commit]
    verbose = true

[delta]
    navigate = true

[diff]
    algorithm = histogram
    colorMoved = zebra
    colorMovedWS = allow-indentation-change

[fetch]
    prune = true

[filter "lfs"]
    clean = git-lfs clean -- %f
    process = git-lfs filter-process
    required = true
    smudge = git-lfs smudge -- %f

[help]
    autocorrect = prompt

[include]
    path = /opt/homebrew/share/git-delta/themes.gitconfig
    path = ~/.config/delta/themes/catppuccin.gitconfig
    path = ~/.config/delta/mode.gitconfig

[init]
    defaultBranch = main

[interactive]
    diffFilter = delta --color-only

[merge]
    conflictStyle = zdiff3

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[rebase]
    autoStash = true
    autoSquash = true
    updateRefs = true

[rerere]
    enabled = true
    required = true

# Push to GitHub over SSH (key auth) but keep clone/fetch on HTTPS, so keyless
# fetches still work (brew taps, public CI). Plain `insteadOf` would force
# fetches over SSH too and break keyless clones.
[url "ssh://git@github.com"]
    pushInsteadOf = https://github.com

