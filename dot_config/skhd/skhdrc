# Focus space
alt - n : yabai -m space --focus prev
alt - m : yabai -m space --focus next
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9

# Focus window
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# Move window
cmd + alt - h : yabai -m window --swap west
cmd + alt - j : yabai -m window --swap south
cmd + alt - k : yabai -m window --swap north
cmd + alt - l : yabai -m window --swap east

# Move window to space
cmd + alt - n : yabai -m window --space prev
cmd + alt - m : yabai -m window --space next
cmd + alt - 1 : yabai -m window --space 1
cmd + alt - 2 : yabai -m window --space 2
cmd + alt - 3 : yabai -m window --space 3
cmd + alt - 4 : yabai -m window --space 4
cmd + alt - 5 : yabai -m window --space 5
cmd + alt - 6 : yabai -m window --space 6
cmd + alt - 7 : yabai -m window --space 7
cmd + alt - 8 : yabai -m window --space 8
cmd + alt - 9 : yabai -m window --space 9

# Resize (push border outward)
cmd + alt - left  : yabai -m window --resize left:-20:0 2>/dev/null || yabai -m window --resize right:-20:0
cmd + alt - right : yabai -m window --resize right:20:0 2>/dev/null || yabai -m window --resize left:20:0
cmd + alt - up    : yabai -m window --resize top:0:-20 2>/dev/null || yabai -m window --resize bottom:0:-20
cmd + alt - down  : yabai -m window --resize bottom:0:20 2>/dev/null || yabai -m window --resize top:0:20

# Toggle float / fullscreen
alt - t : yabai -m window --toggle float
alt - f : yabai -m window --toggle zoom-fullscreen

# Rotate tree
alt - r : yabai -m space --rotate 90

# Balance splits
shift + alt - 0 : yabai -m space --balance

# Restart skhd / yabai
shift + alt - q : yabai --restart-service
shift + alt - e : skhd --restart-service

# Open terminal — the script handles the cold-launch and float-rule subtleties
alt - return : ~/.scripts/ghostty/open-new-window.sh
shift + alt - return : ~/.scripts/ghostty/open-new-window.sh --float
