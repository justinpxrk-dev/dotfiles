# Modifier grammar (hjkl = left/down/up/right):
#   alt          focus window (hjkl) / space (n, m, 1-9)
#   alt + shift  resize window (hjkl)
#   ctrl + alt   move window — swap in place (hjkl), send to space (n, m, 1-9)
#   cmd + alt    intentionally unbound — falls through to Ghostty splits
#                (see ~/.config/ghostty/config.ghostty). Do not bind it here.

# Focus space
alt - n : yabai -m space --focus prev
alt - m : yabai -m space --focus next
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9

# Focus window
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# Move window — swap in place
ctrl + alt - h : yabai -m window --swap west
ctrl + alt - j : yabai -m window --swap south
ctrl + alt - k : yabai -m window --swap north
ctrl + alt - l : yabai -m window --swap east

# Move window to space
ctrl + alt - n : yabai -m window --space prev
ctrl + alt - m : yabai -m window --space next
ctrl + alt - 1 : yabai -m window --space 1
ctrl + alt - 2 : yabai -m window --space 2
ctrl + alt - 3 : yabai -m window --space 3
ctrl + alt - 4 : yabai -m window --space 4
ctrl + alt - 5 : yabai -m window --space 5
ctrl + alt - 6 : yabai -m window --space 6
ctrl + alt - 7 : yabai -m window --space 7
ctrl + alt - 8 : yabai -m window --space 8
ctrl + alt - 9 : yabai -m window --space 9

# Resize window — push border outward (hjkl)
alt + shift - h : yabai -m window --resize left:-20:0 2>/dev/null || yabai -m window --resize right:-20:0
alt + shift - j : yabai -m window --resize bottom:0:20 2>/dev/null || yabai -m window --resize top:0:20
alt + shift - k : yabai -m window --resize top:0:-20 2>/dev/null || yabai -m window --resize bottom:0:-20
alt + shift - l : yabai -m window --resize right:20:0 2>/dev/null || yabai -m window --resize left:20:0

# Toggle float / fullscreen
alt - t : yabai -m window --toggle float
alt - f : yabai -m window --toggle zoom-fullscreen

# Rotate tree
alt - r : yabai -m space --rotate 90

# Balance splits
shift + alt - 0 : yabai -m space --balance

# Restart skhd / yabai
shift + alt - q : yabai --restart-service
shift + alt - e : skhd --restart-service

# Open terminal — the script handles the cold-launch and float-rule subtleties
alt - return : ~/.scripts/ghostty/open-new-window.sh
shift + alt - return : ~/.scripts/ghostty/open-new-window.sh --float
