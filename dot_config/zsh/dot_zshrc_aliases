#!/usr/bin/env zsh
# shellcheck shell=bash

# Contains aliases for interactive zsh shells.

# Core replacements
alias cat=bat
alias df=duf
alias du=dust
alias find=fd
alias grep=rg
alias ls=eza

# Editor
alias edit="\$EDITOR"

# Dotfiles
alias edit-aliases="edit \$DOTFILES/dot_config/zsh/dot_zshrc_aliases"
alias edit-dot="code \$DOTFILES/dotfiles.code-workspace"
# homebrew
alias brewload="brew update && brew upgrade && brew cleanup"
# ls
alias lsa="ls -al"
# nvim
alias vi=nvim
alias vim=nvim
