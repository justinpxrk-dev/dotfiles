#!/usr/bin/env zsh
# shellcheck shell=bash disable=SC2154

# Contains aliases for interactive zsh shells.

# Core replacements — only alias if the replacement is installed so a
# missing tool can't brick the base command (e.g. on a fresh machine).
(($+commands[bat])) && alias cat=bat
(($+commands[duf])) && alias df=duf
(($+commands[dust])) && alias du=dust
(($+commands[eza])) && alias ls=eza
# fd/rg have incompatible CLIs vs find/grep — use distinct aliases instead
# of shadowing the POSIX commands so copy-pasted invocations still work.
(($+commands[fd])) && alias f=fd
(($+commands[rg])) && alias g=rg

# zsh
alias ..="cd .."
alias back="popd"
alias recomp="compinit -d \$ZSH_COMPDUMP"
alias reload="source \$ZSH_CONFIG_HOME/.zshrc"
# Dotfiles
alias .cd="cd \$DOTFILES"
# Run claude in the dotfiles dir without changing the caller's cwd.
(($+commands[claude])) && alias .claude="(cd \$DOTFILES && claude)"
alias .aliases="\$EDITOR \$DOTFILES/dot_config/zsh/dot_zshrc_aliases"
alias .borders="\$EDITOR \$DOTFILES/dot_config/borders/executable_bordersrc.tmpl"
alias .brew="\$EDITOR \$DOTFILES/dot_Brewfile"
alias .chezmoi="\$EDITOR \$DOTFILES/dot_config/chezmoi/chezmoi.toml"
alias .ghostty="\$EDITOR \$DOTFILES/dot_config/ghostty/config.ghostty"
alias .git="\$EDITOR \$DOTFILES/dot_config/git/config"
alias .nvim="\$EDITOR \$DOTFILES/dot_config/nvim/init.lua"
alias .skhd="\$EDITOR \$DOTFILES/dot_config/skhd/skhdrc"
alias .tmux="\$EDITOR \$DOTFILES/dot_config/tmux/tmux.conf"
alias .yabai="\$EDITOR \$DOTFILES/dot_config/yabai/executable_yabairc"
(($+commands[zed])) && alias .zed="zed \$DOTFILES"
# homebrew
(($+commands[brew])) && alias brewload="brew update && brew upgrade && brew cleanup"
# ls
alias lsa="ls -al"
# nvim — fall back to the real vi/vim if nvim isn't installed.
(($+commands[nvim])) && alias vi=nvim
(($+commands[nvim])) && alias vim=nvim

# git
# Browse worktrees interactively in tig
function twig() {
	local worktree
	worktree=$(git worktree list --porcelain | awk '/^worktree/ {print $2}' | fzf)
	[[ -n "$worktree" ]] && tig -C "$worktree"
}
