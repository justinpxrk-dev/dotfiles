#!/usr/bin/env bash

# Tiling layout
yabai -m config layout bsp
yabai -m config auto_balance off
yabai -m config split_ratio 0.50

# Padding around screen edges
yabai -m config top_padding 18
yabai -m config bottom_padding 66
yabai -m config left_padding 18
yabai -m config right_padding 18

# Gap between windows
yabai -m config window_gap 18

# Rules
yabai -m rule --add app="^Activity Monitor$" manage=off
yabai -m rule --add app="^App Store$" manage=off
yabai -m rule --add app="^Archive Utility$" manage=off
yabai -m rule --add app="^BetterDisplay$" manage=off
yabai -m rule --add app="^Bitwarden$" manage=off
yabai -m rule --add app="^Claude$" manage=off
yabai -m rule --add app="^Contacts$" manage=off
yabai -m rule --add app="^Copilot$" manage=off
yabai -m rule --add app="^Equinox$" manage=off
yabai -m rule --add app="^Finder$" manage=off
yabai -m rule --add app="^Font Book$" manage=off
yabai -m rule --add app="^Ghostty$" title="^􀩼$" manage=off grid=8:8:3:2:2:4
yabai -m rule --add app="^MacParakeet$" manage=off
yabai -m rule --add app="^Messages$" manage=off
yabai -m rule --add app="^OrbStack$" manage=off
yabai -m rule --add app="^pCloud Drive$" manage=off
yabai -m rule --add app="^Proton VPN$" manage=off
yabai -m rule --add app="^Raycast$" manage=off
yabai -m rule --add app="^Razer$" manage=off
yabai -m rule --add app="^Reminders$" manage=off
yabai -m rule --add app="^SF Symbols$" manage=off
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Thaw$" manage=off
yabai -m rule --add app="^Weather$" manage=off

# Signals — spaces live on the external sketchybar instance, so route their
# refresh there. `exec -a external` selects git.felix.external (argv[0] picks the
# instance); a bare sketchybar would hit the default top bar.
yabai -m signal --add event=space_created action="exec -a external /opt/homebrew/bin/sketchybar --trigger spaces_change"
yabai -m signal --add event=space_destroyed action="exec -a external /opt/homebrew/bin/sketchybar --trigger spaces_change"
yabai -m signal --add event=space_changed action="exec -a external /opt/homebrew/bin/sketchybar --trigger spaces_change"

# Mirror each display's sketchybar with yabai padding: the built-in reclaims its
# bottom (top bar) while the external reserves space for its bottom bar. Keyed by
# display UUID so it survives dock/undock; re-run when a display is added or
# removed, plus once now for the current arrangement.
yabai -m signal --add event=display_added action="~/.scripts/yabai/apply-display-config.sh"
yabai -m signal --add event=display_removed action="~/.scripts/yabai/apply-display-config.sh"
~/.scripts/yabai/apply-display-config.sh
