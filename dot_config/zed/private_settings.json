// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diff_view_style": "unified",
  "buffer_font_family": "MonoLisa Nerd Font",
  "ui_font_family": "SF Pro Display",
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha"
  },
  "show_wrap_guides": true,
  "wrap_guides": [80, 120],
  "session": {
    "trust_all_worktrees": true
  },
  "soft_wrap": "editor_width",
  "show_whitespaces": "boundary",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "vim_mode": true,
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha"
  },
  // Per-theme overrides keyed by theme name. A flat
  // `experimental.theme_overrides` applies to every theme regardless of
  // appearance, so its hardcoded Mocha colors bleed into Latte and keep light
  // mode dark. Mocha base #1e1e2e, Latte base #eff1f5; the f2 alpha is the
  // translucency the blurred window background shows through.
  "theme_overrides": {
    "Catppuccin Mocha": {
      "background.appearance": "blurred",
      "background": "#1e1e2ef2",
      "editor.background": "#00000000",
      "editor.gutter.background": "#00000000",
      "panel.background": "#00000000",
      "terminal.background": "#00000000",
      "scrollbar.track.background": "#00000000",
      "scrollbar.track.border": "#00000000",
      "tab_bar.background": "#1e1e2ef2",
      "toolbar.background": "#1e1e2ef2",
      "title_bar.background": "#1e1e2ef2",
      "status_bar.background": "#1e1e2ef2",
      "tab.inactive_background": "#1e1e2ef2",
      "tab.active_background": "#1e1e2ef2"
    },
    "Catppuccin Latte": {
      "background.appearance": "blurred",
      "background": "#eff1f5f2",
      "editor.background": "#00000000",
      "editor.gutter.background": "#00000000",
      "panel.background": "#00000000",
      "terminal.background": "#00000000",
      "scrollbar.track.background": "#00000000",
      "scrollbar.track.border": "#00000000",
      "tab_bar.background": "#eff1f5f2",
      "toolbar.background": "#eff1f5f2",
      "title_bar.background": "#eff1f5f2",
      "status_bar.background": "#eff1f5f2",
      "tab.inactive_background": "#eff1f5f2",
      "tab.active_background": "#eff1f5f2"
    }
  }
}
