#!/usr/bin/env lua

package.cpath = package.cpath .. ";" .. os.getenv("HOME") .. "/.local/share/sketchybar_lua/?.so"

-- Catppuccin palette rock (installed via LuaRocks by the bootstrap script). The
-- 5.5 tracks Homebrew's Lua / SbarLua's pin; see docs/ops/upgrade-hazards.md.
package.path = package.path
	.. ";" .. os.getenv("HOME") .. "/.luarocks/share/lua/5.5/?.lua"
	.. ";" .. os.getenv("HOME") .. "/.luarocks/share/lua/5.5/?/init.lua"

local sbar = require("sketchybar")

-- Bundle the entire initial configuration into a single message to sketchybar. This improves startup times drastically.
sbar.begin_config()
require("init")
-- Enables hotloading of sketchybar config. ONLY ENABLE DURING DEVELOPMENT!!!
-- sbar.hotload(true)
sbar.end_config()
sbar.event_loop()
